---
const items = [
  ['text-blue', '1,000+ B2B creators in network'],
  ['text-violet', '$10M+ GMV through webinars'],
  ['text-emerald', '1,000+ live hours'],
  ['text-amber', 'Trust → Trust → Revenue'],
];
---

<section class="border-y border-line bg-white py-6" aria-label="Proof points">
  <div class="marquee">
    {[0, 1].map((copy) => (
      <div class="marquee__track" aria-hidden={copy === 1 ? 'true' : undefined}>
        {items.map(([color, item]) => (
          <div class="flex flex-none items-center gap-5 px-6 text-xl font-extrabold text-ink md:px-10">
            <span class={color} aria-hidden="true">●</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>
