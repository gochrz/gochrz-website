---
const items = [
  { metric: '$10k → $100k+ /mo', descriptor: 'creator education' },
  { metric: '$100k+ /mo', descriptor: 'paid webinar growth system' },
  { metric: '$0 → $100k+ MRR', descriptor: 'webinar subscription system' },
  { metric: '$5k → $20k /mo', descriptor: 'martech SaaS' },
  { metric: 'Multi-6 figures', descriptor: 'founder-led B2B services' },
  { metric: '1 → 1,000+ users', descriptor: 'edtech platform' },
  { metric: '$45k → $60k /webinar', descriptor: 'coaching business' },
  { metric: '20 contracts closed', descriptor: 'LinkedIn outbound system' },
  { metric: '$100k+ /mo', descriptor: 'email-to-webinar monetization' },
];
---

<section class="border-y border-line py-4" aria-label="Revenue system results">
  <div class="marquee">
    {
      [false, true].map((hidden) => (
        <div class="marquee__track" aria-hidden={hidden ? 'true' : undefined}>
          {items.map((item) => (
            <div class="mono-data flex shrink-0 items-center gap-4 px-4 text-sm sm:px-6">
              <span class="text-text">{item.metric}</span>
              <span class="text-muted">— {item.descriptor}</span>
              <span class="text-amber" aria-hidden="true">▸</span>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</section>
