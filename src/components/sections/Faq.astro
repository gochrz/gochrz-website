---
const questions = [
  {
    question: 'How fast can this go live?',
    answer: 'Initial systems typically launch within weeks, not months.',
  },
  {
    question: 'Which channel should we start with?',
    answer: 'The one that removes your current revenue constraint. We select it from your data, not from trends.',
  },
  {
    question: 'Is this outbound, paid, or organic?',
    answer: 'Yes — but never all at once. One primary channel, one support channel.',
  },
  {
    question: 'Is this predictable?',
    answer: 'Yes. Inputs are controlled, so outputs become measurable and repeatable.',
  },
];
---

<section id="faq" class="border-t border-line py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 flex items-center justify-between gap-4">
      <span class="mono-label">SYS/08 — FAQ</span>
    </div>

    <div class="reveal max-w-3xl">
      <h2 class="display-sub text-[clamp(1.8rem,4.5vw,3.2rem)]">
        Questions, answered.
      </h2>
    </div>

    <div class="mt-12 max-w-3xl">
      {
        questions.map((item, index) => (
          <details class="group reveal border-t border-line last:border-b" data-reveal-delay={String(index * 0.08)}>
            <summary class="mono-data flex cursor-pointer list-none justify-between gap-6 py-5 text-base text-text [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <span class="text-amber" aria-hidden="true">
                <span class="group-open:hidden">+</span>
                <span class="hidden group-open:inline">–</span>
              </span>
            </summary>
            <p class="pb-5 leading-relaxed text-muted">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
