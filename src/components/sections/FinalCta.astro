---
import { Icon } from 'astro-icon/components';

const calendlyUrl = 'https://calendly.com/ben-chrzanowski/chrz-intro-call';

const pillarIcons = [
  ['lucide:users', 'bg-blue'],
  ['lucide:radio', 'bg-violet'],
  ['lucide:trending-up', 'bg-emerald'],
];
---

<section id="book" class="relative overflow-hidden bg-ink py-20 text-white md:py-28">
  <div class="mesh-bg mesh-bg--dark" aria-hidden="true">
    <span class="mesh-blob left-[-8rem] top-10 bg-blue"></span>
    <span class="mesh-blob right-[-7rem] top-12 bg-violet"></span>
    <span class="mesh-blob bottom-0 left-1/3 bg-cyan"></span>
    <span class="mesh-blob right-1/4 top-40 bg-amber opacity-[0.1]"></span>
  </div>
  <div class="section-shell relative text-center">
    <div class="reveal mx-auto max-w-4xl">
      <div class="mx-auto flex w-fit items-center gap-2" aria-hidden="true">
        {
          pillarIcons.map(([icon, badgeClass], index) => (
            <>
              <span class={`flex h-10 w-10 items-center justify-center rounded-xl text-white ${badgeClass}`}>
                <Icon name={icon} class="h-5 w-5" />
              </span>
              {index < 2 && <span class="h-px w-6 bg-slate-600" />}
            </>
          ))
        }
      </div>
      <h2 class="mt-8 text-4xl font-extrabold leading-tight sm:text-5xl">
        Ready to build your growth system?
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-300">
        Book a call and we'll map the three pillars to your business.
      </p>
      <a href={calendlyUrl} target="_blank" rel="noopener" class="primary-button group mt-10">
        <Icon name="lucide:calendar" class="h-5 w-5" aria-hidden="true" />
        Book a Systems Call
        <span aria-hidden="true" class="button-arrow">→</span>
      </a>
    </div>
  </div>
</section>
