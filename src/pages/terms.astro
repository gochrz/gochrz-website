---
import LegalLayout from '../layouts/LegalLayout.astro';
import * as Terms from '../content/legal/terms.md';

const { title, subtitle, lastUpdated } = Terms.frontmatter;
---

<LegalLayout
  title={title}
  pageTitle="Terms of Service — CHRZ"
  description={subtitle}
  eyebrow="Terms of Service"
  subtitle={subtitle}
  lastUpdated={lastUpdated}
>
  <article class="legal-prose">
    <Terms.Content />
  </article>
</LegalLayout>
