---
import { Icon } from 'astro-icon/components';

const activations = ['Industry creators', 'Operators', 'Consultants', 'Founders', 'Subject matter experts'];

const campaigns = [
  ['lucide:handshake', 'Creator Partnerships', 'Long-term relationships between brands and creators.'],
  ['lucide:presentation', 'Joint Webinars', 'Creators bring the audience. Companies bring the offer.'],
  ['lucide:megaphone', 'Content Campaigns', 'Creator-led content distributed across multiple channels.'],
  ['lucide:calendar-days', 'Event Partnerships', 'Industry personalities integrated into launches and events.'],
];

const social = ['LinkedIn Content', 'Short Form Video', 'Long Form Content', 'Podcasts', 'Authority Building', 'Personal Branding'];
---

<section id="influencer" class="bg-white py-20 md:py-28">
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="reveal">
        <div class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-[#eff6ff] text-blue">
            <Icon name="lucide:users" class="h-6 w-6" aria-hidden="true" />
          </span>
          <p class="eyebrow text-blue">PILLAR 01 — B2B INFLUENCER MARKETING</p>
        </div>
        <h2 class="mt-6 text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
          Trust is transferred.
        </h2>
        <p class="mt-6 text-xl leading-9 text-body">
          AI can generate anyone's content. Influential creators generate trust.
        </p>
        <div class="relative mt-10 overflow-hidden rounded-2xl border border-line bg-[#eff6ff] p-7">
          <Icon
            name="lucide:users"
            class="absolute -bottom-6 -right-6 h-36 w-36 text-blue opacity-[0.08]"
            aria-hidden="true"
          />
          <p class="gradient-text font-display text-6xl font-extrabold">1,000+</p>
          <p class="mt-3 text-lg font-bold text-ink">B2B creators in network</p>
        </div>
      </div>

      <div class="space-y-6">
        <div class="reveal rounded-2xl border border-line bg-white p-7 shadow-xl shadow-blue/5">
          <h3 class="text-xl font-extrabold text-ink">We identify and activate</h3>
          <div class="mt-5 flex flex-wrap gap-3">
            {
              activations.map((item) => (
                <span class="rounded-full bg-[#eff6ff] px-4 py-2 text-sm font-bold text-blue">{item}</span>
              ))
            }
          </div>
        </div>

        <h3 class="reveal text-xl font-extrabold text-ink">Campaign types</h3>
        <div class="grid gap-x-8 gap-y-7 sm:grid-cols-2">
          {
            campaigns.map(([icon, title, body], index) => (
              <div class="reveal border-t-2 border-line pt-5" data-reveal-delay={index * 0.06}>
                <div class="flex items-center gap-3">
                  <span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-[#eff6ff] text-blue">
                    <Icon name={icon} class="h-5 w-5" aria-hidden="true" />
                  </span>
                  <h3 class="text-lg font-extrabold text-ink">{title}</h3>
                </div>
                <p class="mt-3 leading-7 text-body">{body}</p>
              </div>
            ))
          }
        </div>

        <div class="gradient-border reveal overflow-hidden rounded-2xl border border-line bg-white p-7 shadow-xl shadow-violet/10">
          <div class="flex items-center gap-2.5">
            <Icon name="lucide:clapperboard" class="h-5 w-5 text-blue" aria-hidden="true" />
            <p class="eyebrow text-blue">We'll make you famous.</p>
          </div>
          <h3 class="mt-4 text-xl font-extrabold text-ink">Social Production for Founders</h3>
          <p class="mt-3 text-2xl font-extrabold leading-tight text-ink">
            Turn founders, operators, and creators into media companies.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            {
              social.map((item) => (
                <span class="rounded-full bg-surface px-4 py-2 text-sm font-bold text-ink">{item}</span>
              ))
            }
          </div>
          <p class="mt-7 text-lg font-extrabold text-ink">
            Faster trust, lower acquisition costs, and higher conversion rates.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
