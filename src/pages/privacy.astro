---
import LegalLayout from '../layouts/LegalLayout.astro';
import * as Privacy from '../content/legal/privacy.md';

const { title, subtitle, lastUpdated } = Privacy.frontmatter;
---

<LegalLayout
  title={title}
  pageTitle="Privacy Policy — CHRZ"
  description={subtitle}
  eyebrow="Privacy Policy"
  subtitle={subtitle}
  lastUpdated={lastUpdated}
>
  <article class="legal-prose">
    <Privacy.Content />
  </article>
</LegalLayout>
