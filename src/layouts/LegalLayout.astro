---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/sections/Footer.astro';

interface Props {
  title: string;
  description?: string;
  pageTitle?: string;
  eyebrow: string;
  subtitle: string;
  lastUpdated: string;
}

const { title, description, pageTitle, eyebrow, subtitle, lastUpdated } = Astro.props;
---

<Layout title={pageTitle ?? title} description={description ?? subtitle}>
  <Header />
  <main>
    <section class="mx-auto max-w-3xl px-4 pt-32 pb-24 sm:px-6">
      <div class="border-b border-line pb-10">
        <a href="/" class="eyebrow text-blue transition-colors hover:text-ink">Back to home</a>
        <p class="eyebrow mt-12 text-blue">{eyebrow}</p>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight text-ink sm:text-5xl">{title}</h1>
        <p class="mt-6 text-lg leading-8 text-body">{subtitle}</p>
        <p class="eyebrow mt-8 text-amber-deep">Last updated: {lastUpdated}</p>
      </div>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(.legal-prose) {
    margin-top: 3rem;
  }

  :global(.legal-prose p) {
    color: var(--color-body);
    line-height: 1.7;
    font-size: 1rem;
    margin-top: 1.25rem;
  }

  :global(.legal-prose h2) {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--color-ink);
    font-size: 1.5rem;
    line-height: 1.2;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }

  :global(.legal-prose h3) {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-amber-deep);
    font-weight: 700;
    margin-top: 2rem;
  }

  :global(.legal-prose ul) {
    list-style: none;
    padding-left: 0;
    margin-top: 1.25rem;
  }

  :global(.legal-prose ul ul) {
    margin-top: 0.75rem;
    padding-left: 1.5rem;
  }

  :global(.legal-prose li) {
    position: relative;
    color: var(--color-body);
    line-height: 1.7;
    margin-top: 0.5rem;
    padding-left: 1.35rem;
  }

  :global(.legal-prose ul > li::before) {
    content: '';
    position: absolute;
    top: 0.7rem;
    left: 0.15rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: var(--color-blue);
  }

  :global(.legal-prose ul ul > li::before) {
    background: var(--color-line);
  }

  :global(.legal-prose ol) {
    list-style: decimal;
    margin-top: 1.25rem;
    padding-left: 1.4rem;
  }

  :global(.legal-prose ol > li) {
    padding-left: 0.4rem;
  }

  :global(.legal-prose ol > li::before) {
    content: none;
  }

  :global(.legal-prose ol > li::marker) {
    color: var(--color-amber-deep);
    font-weight: 700;
  }

  :global(.legal-prose strong) {
    color: var(--color-ink);
  }

  :global(.legal-prose a) {
    color: var(--color-blue);
    text-decoration: none;
  }

  :global(.legal-prose a:hover) {
    text-decoration: underline;
  }
</style>
