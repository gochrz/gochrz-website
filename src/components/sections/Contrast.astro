---
const contrasts = [
  {
    code: 'NOT/01',
    title: 'This is not a campaign model.',
    body: 'Campaigns spike. Systems compound.',
  },
  {
    code: 'NOT/02',
    title: 'This is not channel testing.',
    body: 'Channels are selected based on constraints — not trends.',
  },
];
---

<section class="border-t border-line py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 flex items-center justify-between gap-4">
      <span class="mono-label">SYS/06 — What this is not</span>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {
        contrasts.map((item, index) => (
          <article class="panel reveal p-6 md:p-8" data-reveal-delay={String(index * 0.1)}>
            <span class="mono-label text-fault">{item.code}</span>
            <h2 class="display-sub mt-5 text-[clamp(1.8rem,4.5vw,3.2rem)]">{item.title}</h2>
            <p class="mt-5 text-lg leading-relaxed text-muted">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
