---
const phases = [
  {
    window: 'Weeks 1–2',
    title: 'Revenue system definition',
    focus: 'Focus: remove ambiguity before execution.',
  },
  {
    window: 'Weeks 3–4',
    title: 'System activation',
    focus: 'Focus: turn the system on.',
  },
  {
    window: 'Month 2',
    title: 'Stabilization & control',
    focus: 'Focus: improve performance without adding complexity.',
  },
  {
    window: 'Month 3',
    title: 'Scale or hold',
    focus: 'Focus: lock in predictability.',
  },
];
---

<section id="install" class="border-t border-line py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 flex items-center justify-between gap-4">
      <span class="mono-label">SYS/05 — Install plan</span>
    </div>

    <div class="reveal max-w-3xl">
      <h2 class="display-sub text-[clamp(1.8rem,4.5vw,3.2rem)]">
        The first 90 days.
      </h2>
    </div>

    <div class="relative mt-14" data-draw-scope>
      <svg class="absolute left-3 top-0 h-full w-6 md:left-8" viewBox="0 0 24 100" preserveAspectRatio="none" aria-hidden="true">
        <path data-draw-path d="M 12 0 V 100" stroke="var(--color-cobalt)" stroke-width="2" fill="none"></path>
      </svg>

      <div class="space-y-5 pl-12 md:pl-24">
        {
          phases.map((phase, index) => (
            <article class="panel bracket reveal p-6" data-reveal-delay={(index / 10).toFixed(1)}>
              <span class="mono-label">{phase.window}</span>
              <h3 class="display-sub mt-4 text-xl">{phase.title}</h3>
              <p class="mt-4 text-muted">{phase.focus}</p>
            </article>
          ))
        }
      </div>
    </div>

    <p class="reveal mt-10 max-w-2xl text-muted">
      After 90 days, you either continue scaling or operate the system internally.
    </p>
  </div>
</section>
