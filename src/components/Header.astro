---
const nav = [
  { href: '/#pillars', label: 'Our Pillars' },
  { href: '/#case-studies', label: 'Our Case Studies' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-white/85 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="brand-logo text-2xl text-[#1f2937]" aria-label="CHRZ home">
      CHR<span class="text-blue">Z</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Main" id="header-nav">
      {
        nav.map((item) => (
          <a href={item.href} class="text-sm font-semibold text-slate-600 transition-colors hover:text-ink" data-nav-label={item.label}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="https://calendly.com/ben-chrzanowski/chrz-intro-call"
      target="_blank"
      rel="noopener"
      class="primary-button primary-button--sm group"
      id="header-book-call"
    >
      Book a Systems Call
      <span aria-hidden="true" class="button-arrow">→</span>
    </a>
  </div>
</header>

<script is:inline>
  document.getElementById('header-book-call')?.addEventListener('click', function () {
    window.posthog?.capture('book_call_clicked', { location: 'header' });
  });
  document.getElementById('header-nav')?.addEventListener('click', function (e) {
    var target = e.target.closest('[data-nav-label]');
    if (target) {
      window.posthog?.capture('nav_link_clicked', { label: target.dataset.navLabel });
    }
  });
</script>
