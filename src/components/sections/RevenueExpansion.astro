---
const offers = [
  {
    title: 'High-Ticket Offers',
    body: 'Package expertise into premium products.',
    chips: ['Consulting', 'Advisory', 'Coaching', 'Implementation', 'Done-with-you services'],
  },
  {
    title: 'Education Businesses',
    body: 'Monetize knowledge.',
    chips: ['Courses', 'Communities', 'Cohorts', 'Memberships', 'Certifications'],
  },
  {
    title: 'Service Expansion',
    body: '',
    chips: ['Retainers', 'Managed services', 'Licensing', 'Audits', 'Fractional services'],
  },
];
---

<section id="revenue" class="bg-white py-20 md:py-28">
  <div class="section-shell">
    <div class="reveal max-w-4xl">
      <p class="eyebrow text-emerald">PILLAR 03 — REVENUE EXPANSION</p>
      <h2 class="mt-5 text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        Take the trust you have and scale it.
      </h2>
      <p class="mt-6 text-xl leading-9 text-body">
        Turn existing trust into new revenue streams. SaaS, services, education — scale by offering more to those who already trust you.
      </p>
    </div>

    <h3 class="reveal mt-12 text-xl font-extrabold text-ink">What we build</h3>
    <div class="mt-6 grid gap-6 lg:grid-cols-3">
      {
        offers.map((offer, index) => (
          <div class="lift-card reveal p-7 hover:border-emerald hover:shadow-xl hover:shadow-emerald/15" data-reveal-delay={index * 0.08}>
            <h3 class="text-2xl font-extrabold text-ink">{offer.title}</h3>
            {offer.body && <p class="mt-3 leading-7 text-body">{offer.body}</p>}
            <div class="mt-6 flex flex-wrap gap-3">
              {offer.chips.map((chip) => (
                <span class="rounded-full bg-[#ecfdf5] px-3.5 py-2 text-sm font-bold text-emerald">{chip}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="reveal mt-8 rounded-2xl border border-amber bg-[#fffbeb] p-7 shadow-xl shadow-amber/10">
      <p class="eyebrow text-amber-deep">FOR CREATORS</p>
      <h3 class="mt-4 text-3xl font-extrabold leading-tight text-ink">
        Monetize your audience the right way. Sell education live.
      </h3>
      <p class="mt-4 text-lg font-bold text-ink">
        Education monetization — turn audiences into businesses.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        {['Courses', 'Communities', 'Masterminds', 'Events'].map((chip) => (
          <span class="rounded-full bg-white px-4 py-2 text-sm font-bold text-ink">{chip}</span>
        ))}
      </div>
    </div>

    <p class="reveal mt-10 text-2xl font-extrabold leading-tight text-ink">
      Additional revenue streams built on assets you already own.
    </p>
  </div>
</section>
