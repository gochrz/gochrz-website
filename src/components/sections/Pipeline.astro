---
const stages = ['Traffic', 'Capture', 'Qualification', 'Sales', 'Reporting'];
const includes = [
  'ICP and channel selection',
  'One primary acquisition channel',
  'One secondary support channel',
  'Qualification logic',
  'Weekly reporting',
];
---

<section class="border-t border-line py-24 md:py-32" data-pipeline>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 flex items-center justify-between gap-4">
      <span class="mono-label">SYS/04 — Signal chain</span>
    </div>

    <div class="reveal max-w-4xl">
      <h2 class="display-sub text-[clamp(1.8rem,4.5vw,3.2rem)]">
        Channels alone don't scale. <span class="text-cobalt">Systems do.</span>
      </h2>
    </div>

    <div class="mt-12 flex flex-wrap items-center gap-3">
      {
        stages.map((stage, index) => (
          <>
            <div class="panel mono-data px-5 py-3 text-sm uppercase" data-stage>
              {stage}
            </div>
            {index < stages.length - 1 && (
              <span class="text-amber" aria-hidden="true">→</span>
            )}
          </>
        ))
      }
    </div>

    <div class="panel reveal mt-12 max-w-2xl p-6" data-reveal-delay="0.1">
      <span class="mono-label">A typical revenue system includes</span>
      <div class="mt-5">
        {
          includes.map((item) => (
            <div class="mono-data border-t border-line py-4 text-sm text-text">
              {item}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
