---
const calendlyUrl = 'https://calendly.com/ben-chrzanowski/chrz-intro-call';
---

<section id="top" class="relative overflow-hidden pt-16">
  <div class="mesh-bg" aria-hidden="true">
    <span class="mesh-blob left-[-8rem] top-10 bg-blue"></span>
    <span class="mesh-blob right-[-7rem] top-20 bg-violet"></span>
    <span class="mesh-blob bottom-4 left-1/3 bg-cyan"></span>
    <span class="mesh-blob right-1/4 top-44 bg-amber opacity-[0.1]"></span>
  </div>

  <div class="section-shell relative grid min-h-[calc(100vh-4rem)] items-center gap-12 py-20 lg:grid-cols-[1.04fr_0.96fr]">
    <div class="reveal max-w-3xl">
      <p class="eyebrow text-blue">B2B GROWTH AGENCY</p>
      <h1 class="mt-6 text-5xl font-extrabold leading-[1.02] text-ink sm:text-6xl lg:text-7xl">
        B2B Marketing Designed for the <span class="gradient-text">New World</span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-body sm:text-xl">
        We help B2B SaaS companies, service businesses, and creator businesses generate revenue through live events, industry personalities, and social content.
      </p>
      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a href={calendlyUrl} target="_blank" rel="noopener" class="primary-button group">
          Book a Systems Call
          <span aria-hidden="true" class="button-arrow">→</span>
        </a>
        <a href="#pillars" class="ghost-button">
          See the three pillars ↓
        </a>
      </div>
    </div>

    <div class="reveal relative" data-reveal-delay="0.12">
      <div class="absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-blue/10 via-violet/10 to-cyan/10 blur-2xl" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-2xl border border-line bg-white shadow-2xl shadow-blue/10">
        <div class="grid grid-cols-3 border-b border-line text-center" aria-hidden="true">
          <div class="bg-[#eff6ff] px-4 py-5">
            <p class="text-3xl font-extrabold text-blue">01</p>
          </div>
          <div class="bg-[#f5f3ff] px-4 py-5">
            <p class="text-3xl font-extrabold text-violet">02</p>
          </div>
          <div class="bg-[#ecfdf5] px-4 py-5">
            <p class="text-3xl font-extrabold text-emerald">03</p>
          </div>
        </div>
        <div class="p-6 sm:p-8">
          <div class="rounded-2xl border border-line bg-surface p-5">
            <div class="flex items-center justify-between gap-4" aria-hidden="true">
              <span class="h-3 w-24 rounded-full bg-blue/20"></span>
              <span class="h-3 w-14 rounded-full bg-emerald/20"></span>
            </div>
            <div class="mt-8 grid gap-4">
              <div class="h-3 rounded-full bg-gradient-to-r from-blue via-violet to-cyan"></div>
              <div class="h-3 w-4/5 rounded-full bg-gradient-to-r from-violet to-emerald"></div>
              <div class="h-3 w-3/5 rounded-full bg-gradient-to-r from-emerald to-amber"></div>
            </div>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-4">
            <div class="rounded-2xl border border-line bg-white p-5">
              <p class="gradient-text text-4xl font-extrabold">1,000+</p>
              <p class="mt-2 text-sm font-bold text-body">B2B creators in network</p>
            </div>
            <div class="rounded-2xl border border-line bg-white p-5">
              <p class="gradient-text text-4xl font-extrabold">$10M+</p>
              <p class="mt-2 text-sm font-bold text-body">GMV through webinars</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
