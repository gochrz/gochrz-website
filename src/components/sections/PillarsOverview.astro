---
const pillars = [
  {
    number: '01',
    title: 'B2B Influencer Marketing',
    tagline: 'Trust is transferred.',
    href: '#influencer',
    dotClass: 'bg-blue',
    hoverClass: 'hover:border-blue hover:shadow-blue/15',
    textClass: 'text-blue',
    tint: '#eff6ff',
  },
  {
    number: '02',
    title: 'Digital Live Events',
    tagline: 'Trust is built live.',
    href: '#events',
    dotClass: 'bg-violet',
    hoverClass: 'hover:border-violet hover:shadow-violet/15',
    textClass: 'text-violet',
    tint: '#f5f3ff',
  },
  {
    number: '03',
    title: 'Revenue Expansion',
    tagline: 'Take the trust you have and scale it.',
    href: '#revenue',
    dotClass: 'bg-emerald',
    hoverClass: 'hover:border-emerald hover:shadow-emerald/15',
    textClass: 'text-emerald',
    tint: '#ecfdf5',
  },
];
---

<section id="pillars" class="bg-white py-20 md:py-28">
  <div class="section-shell">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        Our business is built around three pillars that work together.
      </h2>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        pillars.map((pillar, index) => (
          <a
            href={pillar.href}
            class={`lift-card reveal group flex flex-col p-8 hover:shadow-xl ${pillar.hoverClass}`}
            style={`background: linear-gradient(180deg, ${pillar.tint}, #ffffff 55%)`}
            data-reveal-delay={index * 0.08}
          >
            <div class="flex items-center justify-between gap-4">
              <span class={`text-5xl font-extrabold ${pillar.textClass}`}>{pillar.number}</span>
              <span class={`h-3.5 w-3.5 rounded-full ${pillar.dotClass}`}></span>
            </div>
            <h3 class="mt-10 text-2xl font-extrabold leading-tight text-ink">{pillar.title}</h3>
            <p class="mt-3 text-lg font-semibold leading-7 text-body">{pillar.tagline}</p>
            <span class={`mt-8 inline-flex items-center gap-2 text-sm font-extrabold ${pillar.textClass}`}>
              Explore
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <p class="reveal mx-auto mt-14 max-w-3xl text-center text-xl font-semibold leading-8 text-ink">
      Each can be used independently, but they're most powerful when combined into a single growth system.
    </p>
  </div>
</section>
