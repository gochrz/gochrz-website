---
import { Icon } from 'astro-icon/components';

const groups = [
  {
    icon: 'lucide:app-window',
    chipClass: 'bg-[#eff6ff] text-blue',
    hoverClass: 'hover:border-blue hover:shadow-blue/15',
    title: 'SaaS Companies',
    body: 'Get more subscriptions and generate additional revenue streams beyond subscriptions.',
  },
  {
    icon: 'lucide:briefcase-business',
    chipClass: 'bg-[#f5f3ff] text-violet',
    hoverClass: 'hover:border-violet hover:shadow-violet/15',
    title: 'Service Businesses',
    body: 'Create scalable acquisition channels beyond referrals.',
  },
  {
    icon: 'lucide:video',
    chipClass: 'bg-[#ecfdf5] text-emerald',
    hoverClass: 'hover:border-emerald hover:shadow-emerald/15',
    title: 'Creator Businesses',
    body: 'Turn audiences into dollars.',
  },
];
---

<section id="who" class="bg-white py-20 md:py-28">
  <div class="section-shell">
    <div class="reveal">
      <h2 class="text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        Who we work with
      </h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        groups.map((group, index) => (
          <div class={`lift-card reveal p-7 hover:shadow-xl ${group.hoverClass}`} data-reveal-delay={index * 0.08}>
            <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${group.chipClass}`}>
              <Icon name={group.icon} class="h-6 w-6" aria-hidden="true" />
            </span>
            <h3 class="mt-6 text-2xl font-extrabold text-ink">{group.title}</h3>
            <p class="mt-4 leading-8 text-body">{group.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
