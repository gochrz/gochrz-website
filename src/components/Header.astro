---
const nav = [
  { href: '#diagnosis', label: 'Diagnosis' },
  { href: '#systems', label: 'Systems' },
  { href: '#install', label: 'Install plan' },
  { href: '#results', label: 'Results' },
  { href: '#faq', label: 'FAQ' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line bg-ink-0/80 backdrop-blur-md"
>
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="#top" class="display-sub text-lg tracking-tight" aria-label="CHRZ home">
      CHR<span class="text-cobalt">Z</span><span class="text-amber">.</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="mono-label transition-colors hover:text-text"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="#book"
      class="mono-data group inline-flex items-center gap-2 border border-cobalt bg-cobalt px-4 py-2 text-xs font-medium text-white transition-colors hover:bg-transparent hover:text-cobalt"
    >
      Book a systems call
      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
    </a>
  </div>
</header>
