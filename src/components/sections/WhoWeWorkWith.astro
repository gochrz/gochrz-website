---
import { Icon } from 'astro-icon/components';

const groups = [
  {
    icon: 'lucide:app-window',
    accent: '#4f46e5',
    tint: 'rgba(79,70,229,0.07)',
    shadow: 'rgba(79,70,229,0.28)',
    title: 'SaaS Companies',
    body: 'Get more subscriptions and generate additional revenue streams beyond subscriptions.',
    tag: 'Recurring revenue engines →',
  },
  {
    icon: 'lucide:briefcase-business',
    accent: '#8b5cf6',
    tint: 'rgba(139,92,246,0.07)',
    shadow: 'rgba(139,92,246,0.28)',
    title: 'Service Businesses',
    body: 'Create scalable acquisition channels beyond referrals.',
    tag: 'Pipeline you control →',
  },
  {
    icon: 'lucide:video',
    accent: '#10b981',
    tint: 'rgba(16,185,129,0.08)',
    shadow: 'rgba(16,185,129,0.28)',
    title: 'Creator Businesses',
    body: 'Turn audiences into dollars.',
    tag: 'Attention → income →',
  },
];
---

<section id="who" class="bg-white pt-20 md:pt-28">
  <div class="section-shell">
    <div class="reveal">
      <div class="who-eyebrow">
        <span class="who-dot" aria-hidden="true"></span>
        Who we work with
      </div>
      <h2 class="who-heading">Built for teams ready to <em>systemize growth</em></h2>
      <p class="who-sub">
        Three business models, one playbook: predictable acquisition that doesn't depend on luck, referrals, or the algorithm.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        groups.map((group, index) => (
          <div
            class="who-card reveal"
            style={`--accent:${group.accent};--tint:${group.tint};--shadow:${group.shadow}`}
            data-reveal-delay={index * 0.08}
          >
            <span class="who-icon-tile">
              <Icon name={group.icon} class="h-6 w-6" aria-hidden="true" />
            </span>
            <h3>{group.title}</h3>
            <p>{group.body}</p>
            <span class="who-tag">{group.tag}</span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="who-break" data-pipeline>
    <div class="pipeline" aria-hidden="true">
      <span class="rail"></span>
      <span class="spark"></span>
    </div>
    <div class="pipeline-badge">The system in action</div>
  </div>
</section>

<style>
  .who-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    border: 1px solid #dde1ff;
    border-radius: 100px;
    background: #eef0ff;
    padding: 7px 14px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4f46e5;
  }

  @keyframes who-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(79, 70, 229, 0.45);
    }

    50% {
      box-shadow: 0 0 0 6px rgba(79, 70, 229, 0);
    }
  }

  .who-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4f46e5;
    animation: who-pulse 2.2s ease-in-out infinite;
  }

  .who-heading {
    max-width: 640px;
    font-size: clamp(34px, 4.5vw, 52px);
    font-weight: 700;
    line-height: 1.08;
    color: var(--color-ink);
  }

  .who-heading em {
    font-style: normal;
    background: linear-gradient(92deg, #4f46e5, #8b5cf6 55%, #10b981);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .who-sub {
    margin-top: 16px;
    max-width: 520px;
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-body);
  }

  .who-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 18px;
    background: #ffffff;
    padding: 30px 28px 28px;
    transition:
      transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }

  .who-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--tint) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .who-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 3px;
    width: 100%;
    background: linear-gradient(90deg, var(--accent), transparent 85%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .who-card:hover {
    transform: translateY(-8px);
    border-color: transparent;
    box-shadow:
      0 24px 48px -18px var(--shadow),
      0 4px 14px rgba(16, 18, 38, 0.05);
  }

  .who-card:hover::before {
    opacity: 1;
  }

  .who-card:hover::after {
    transform: scaleX(1);
  }

  .who-icon-tile {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: 22px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--accent) 10%, white);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, white);
    color: var(--accent);
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .who-card:hover .who-icon-tile {
    transform: rotate(-6deg) scale(1.1);
  }

  .who-card h3 {
    position: relative;
    margin-bottom: 10px;
    font-size: 20px;
    font-weight: 600;
    color: var(--color-ink);
  }

  .who-card p {
    position: relative;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-body);
  }

  .who-tag {
    position: relative;
    display: inline-block;
    margin-top: 20px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 9%, white);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, white);
    padding: 5px 11px;
    border-radius: 100px;
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.4s ease 0.08s,
      transform 0.4s ease 0.08s;
  }

  .who-card:hover .who-tag {
    opacity: 1;
    transform: translateY(0);
  }

  .who-break {
    position: relative;
    height: 190px;
    margin-top: 3rem;
    background: linear-gradient(180deg, #ffffff 0%, #f6f7fd 100%);
  }

  @media (max-width: 880px) {
    .who-break {
      height: 150px;
    }
  }

  .pipeline {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    height: 100%;
    width: 3px;
  }

  .pipeline .rail {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #4f46e5, #8b5cf6 50%, #10b981);
    border-radius: 3px;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s;
  }

  .who-break.in .pipeline .rail {
    transform: scaleY(1);
  }

  @keyframes who-travel {
    0% {
      top: -4px;
      opacity: 0;
    }

    12% {
      opacity: 1;
    }

    88% {
      opacity: 1;
    }

    100% {
      top: calc(100% - 6px);
      opacity: 0;
    }
  }

  .pipeline .spark {
    position: absolute;
    left: 50%;
    top: 0;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: white;
    border: 3px solid #8b5cf6;
    transform: translateX(-50%);
    box-shadow:
      0 0 0 5px rgba(139, 92, 246, 0.15),
      0 0 18px rgba(139, 92, 246, 0.5);
    animation: who-travel 2.6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    animation-play-state: paused;
  }

  .who-break.in .pipeline .spark {
    animation-play-state: running;
  }

  .pipeline-badge {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) scale(0.85);
    background: white;
    border: 1px solid var(--color-line);
    border-radius: 100px;
    padding: 9px 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-body);
    box-shadow: 0 8px 24px rgba(16, 18, 38, 0.08);
    white-space: nowrap;
    opacity: 0;
    transition:
      opacity 0.6s ease 0.5s,
      transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s;
  }

  .who-break.in .pipeline-badge {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .who-break .rail {
      transform: scaleY(1);
    }

    .pipeline-badge {
      opacity: 1;
      transform: translate(-50%, -50%);
    }
  }
</style>

<script>
  const breakEl = document.querySelector('[data-pipeline]');

  if (breakEl) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            breakEl.classList.add('in');
            observer.unobserve(breakEl);
          }
        });
      },
      { threshold: 0.4 }
    );
    observer.observe(breakEl);
  }
</script>
