---
import { Icon } from 'astro-icon/components';

const activations = ['Industry creators', 'Operators', 'Consultants', 'Founders', 'Subject matter experts'];

const campaigns = [
  ['lucide:handshake', 'Creator Partnerships', 'Long-term relationships between brands and creators.'],
  ['lucide:video', 'Joint Webinars', 'Creators bring the audience. Companies bring the offer.'],
  ['lucide:megaphone', 'Content Campaigns', 'Creator-led content distributed across multiple channels.'],
  ['lucide:calendar-clock', 'Event Partnerships', 'Industry personalities integrated into launches and events.'],
];

const social = ['LinkedIn Content', 'Short Form Video', 'Long Form Content', 'Podcasts', 'Authority Building', 'Personal Branding'];

const audienceDots = [
  { left: '87.5%', top: '26%' },
  { left: '91.4%', top: '50%' },
  { left: '87.5%', top: '74%' },
];
---

<section id="influencer" class="bg-white py-20 md:py-28">
  <div class="section-shell flex max-w-5xl flex-col gap-8">
    <div class="reveal">
      <div class="flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-[#eff6ff] text-blue">
          <Icon name="lucide:users" class="h-6 w-6" aria-hidden="true" />
        </span>
        <p class="eyebrow text-blue">PILLAR 01 · B2B INFLUENCER MARKETING</p>
      </div>
      <h2 class="mt-6 text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        Trust is transferred.
      </h2>
      <p class="mt-5 max-w-md text-xl leading-8 text-body">
        AI can generate anyone's content. Influential creators generate trust.
      </p>
    </div>

    <!-- Trust transfer diagram -->
    <div class="reveal rounded-2xl border border-line bg-white p-6 shadow-xl shadow-blue/5 sm:p-10" data-reveal-delay="0.12">
      <div class="im-diagram relative w-full" aria-hidden="true">
        <svg viewBox="0 0 640 210" class="absolute inset-0 h-full w-full" fill="none">
          <path d="M60,105 Q195,45 320,105" stroke="#bfdbfe" stroke-width="2" stroke-dasharray="1 8" stroke-linecap="round"></path>
          <path d="M320,105 Q450,60 560,55" stroke="#dbeafe" stroke-width="1.5" stroke-dasharray="1 7" stroke-linecap="round"></path>
          <path d="M320,105 L585,105" stroke="#dbeafe" stroke-width="1.5" stroke-dasharray="1 7" stroke-linecap="round"></path>
          <path d="M320,105 Q450,150 560,155" stroke="#dbeafe" stroke-width="1.5" stroke-dasharray="1 7" stroke-linecap="round"></path>

          <circle r="5" fill="#2563eb">
            <animateMotion path="M60,105 Q195,45 320,105" dur="2.4s" repeatCount="indefinite"></animateMotion>
          </circle>
          <circle r="3.5" fill="#7c3aed">
            <animateMotion path="M320,105 Q450,60 560,55" dur="2.4s" begin="2.4s" repeatCount="indefinite"></animateMotion>
          </circle>
          <circle r="3.5" fill="#7c3aed">
            <animateMotion path="M320,105 L585,105" dur="2.4s" begin="2.4s" repeatCount="indefinite"></animateMotion>
          </circle>
          <circle r="3.5" fill="#7c3aed">
            <animateMotion path="M320,105 Q450,150 560,155" dur="2.4s" begin="2.4s" repeatCount="indefinite"></animateMotion>
          </circle>
        </svg>

        {
          audienceDots.map((pos, index) => (
            <span
              class="im-ripple absolute rounded-full"
              style={`left: ${pos.left}; top: ${pos.top}; animation-delay: ${2.4 + index * 0.15}s;`}
            />
          ))
        }

        <div class="im-node-creator absolute flex items-center justify-center rounded-2xl border border-[#bfdbfe] bg-[#eff6ff]">
          <Icon name="lucide:users" class="h-5 w-5 text-blue" />
        </div>
        <p class="im-label" style="left: 9.4%; top: 78%;">CREATOR</p>

        <div class="im-node-brand absolute flex items-center justify-center rounded-2xl">
          <Icon name="lucide:building-2" class="h-6 w-6 text-white" />
        </div>
        <p class="im-label" style="left: 50%; top: 78%;">YOUR BRAND</p>

        {
          audienceDots.map((pos) => (
            <span class="im-dot absolute rounded-full bg-cyan" style={`left: ${pos.left}; top: ${pos.top};`} />
          ))
        }
        <p class="im-label" style="left: 89%; top: 94%;">THEIR AUDIENCE</p>
      </div>
    </div>

    <!-- Count-up stat -->
    <div
      class="reveal flex items-center justify-between rounded-2xl border border-[#dbeafe] px-7 py-6"
      style="background: linear-gradient(135deg, #eff6ff, #f5f3ff)"
      data-reveal-delay="0.2"
    >
      <div>
        <p class="font-display text-4xl font-extrabold leading-none text-blue sm:text-5xl">
          <span id="im-creator-count" data-count-target="1000">0</span>+
        </p>
        <p class="mt-2 font-bold text-ink">B2B creators in network</p>
      </div>
      <span class="hidden h-14 w-14 items-center justify-center rounded-full bg-blue/10 sm:flex">
        <Icon name="lucide:users" class="h-6 w-6 text-blue" aria-hidden="true" />
      </span>
    </div>

    <div class="reveal rounded-2xl border border-line bg-white p-6 shadow-xl shadow-blue/5 sm:p-7" data-reveal-delay="0.1">
      <h3 class="text-xl font-extrabold text-ink">We identify and activate</h3>
      <div class="mt-4 flex flex-wrap gap-2.5">
        {
          activations.map((item) => (
            <span class="rounded-full bg-[#eff6ff] px-4 py-2 text-sm font-bold text-blue">{item}</span>
          ))
        }
      </div>
    </div>

    <div class="reveal" data-reveal-delay="0.15">
      <h3 class="text-xl font-extrabold text-ink">Campaign types</h3>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          campaigns.map(([icon, title, body]) => (
            <div class="im-card relative overflow-hidden rounded-2xl border border-line bg-white p-6">
              <span class="im-accent absolute left-0 top-0 h-full w-[3px]" />
              <span class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-[#eff6ff]">
                <Icon name={icon} class="h-5 w-5 text-blue" aria-hidden="true" />
              </span>
              <h4 class="text-base font-extrabold text-ink">{title}</h4>
              <p class="mt-1.5 text-[15px] leading-7 text-body">{body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="im-border-flow reveal rounded-2xl p-[1.5px]" data-reveal-delay="0.2">
      <div class="rounded-2xl bg-white p-7 sm:p-8">
        <div class="flex items-center gap-2">
          <Icon name="lucide:sparkles" class="h-4 w-4 text-blue" aria-hidden="true" />
          <p class="eyebrow text-blue">We'll make you famous</p>
        </div>
        <p class="mt-4 text-[15px] font-bold text-body">Social Production for Founders</p>
        <h3 class="mt-1.5 text-2xl font-extrabold leading-snug text-ink sm:text-3xl">
          Turn founders, operators, and creators into media companies.
        </h3>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            social.map((item) => (
              <span class="rounded-full bg-surface px-3.5 py-1.5 text-sm font-bold text-ink">{item}</span>
            ))
          }
        </div>
        <p class="mt-6 flex items-center gap-2 text-base font-extrabold text-ink">
          Faster trust, lower acquisition costs, and higher conversion rates.
          <Icon name="lucide:arrow-up-right" class="h-[17px] w-[17px] flex-none text-blue" aria-hidden="true" />
        </p>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .im-diagram {
    aspect-ratio: 640 / 210;
  }

  .im-label {
    position: absolute;
    transform: translateX(-50%);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-body);
    white-space: nowrap;
  }

  .im-node-creator {
    left: 9.4%;
    top: 50%;
    width: 52px;
    height: 52px;
    margin-left: -26px;
    margin-top: -26px;
  }

  .im-node-brand {
    left: 50%;
    top: 50%;
    width: 64px;
    height: 64px;
    margin-left: -32px;
    margin-top: -32px;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    box-shadow: 0 12px 24px -8px rgba(37, 99, 235, 0.45);
  }

  .im-dot {
    width: 12px;
    height: 12px;
    margin-left: -6px;
    margin-top: -6px;
  }

  @keyframes im-ripple {
    0% {
      transform: scale(0.6);
      opacity: 0.7;
    }
    100% {
      transform: scale(2.4);
      opacity: 0;
    }
  }

  .im-ripple {
    width: 16px;
    height: 16px;
    margin-left: -8px;
    margin-top: -8px;
    background: rgba(6, 182, 212, 0.35);
    animation: im-ripple 2.2s ease-out infinite;
  }

  @keyframes im-border-flow {
    0% {
      background-position: 0% 50%;
    }
    100% {
      background-position: 200% 50%;
    }
  }

  .im-border-flow {
    background: linear-gradient(90deg, #2563eb, #7c3aed, #06b6d4, #2563eb);
    background-size: 200% 100%;
    animation: im-border-flow 6s linear infinite;
  }

  .im-card {
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .im-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(37, 99, 235, 0.28);
    border-color: #bfdbfe;
  }

  .im-accent {
    background: linear-gradient(180deg, #2563eb, #06b6d4);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .im-card:hover .im-accent {
    transform: scaleY(1);
  }
</style>

<script>
  const countEl = document.getElementById('im-creator-count');

  if (countEl) {
    const target = Number(countEl.dataset.countTarget ?? 0);
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
      countEl.textContent = target.toLocaleString();
    } else {
      let started = false;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting || started) return;
            started = true;
            const startTime = performance.now();
            const duration = 1400;
            const tick = (now: number) => {
              const progress = Math.min((now - startTime) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              countEl.textContent = Math.round(eased * target).toLocaleString();
              if (progress < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            observer.disconnect();
          });
        },
        { threshold: 0.4 }
      );
      observer.observe(countEl);
    }
  }
</script>
