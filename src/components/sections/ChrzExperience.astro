  { cards: rowA, reverse: false },
  { cards: rowB, reverse: true },
];

const allCards = [...rowA, ...rowB];
---

<section id="case-studies" class="chrz-exp" aria-label="CHRZ's experience and case studies">
  <div class="chrz-exp__head reveal">
    <span class="chrz-exp__pill">Proven Systems</span>
    <h2 class="chrz-exp__title">CHRZ's <em>Experience</em></h2>
    <p class="chrz-exp__sub">Case studies also through Chrz's time building Techrupt Innovations and Teachly.</p>
  </div>

  <!-- Desktop: auto-scrolling marquee rows -->
  {
    rows.map(({ cards, reverse }) => (
      <div class={`chrz-marquee ${reverse ? 'chrz-marquee--reverse' : ''}`}>
        {[0, 1].map((copy) => (
          <div class="chrz-track" aria-hidden={copy === 1 ? 'true' : undefined}>
            {cards.map((card) => (
              <ChrzCard card={card} />
            ))}
          </div>
        ))}
      </div>
    ))
  }

  <!-- Mobile: swipeable carousel -->
  <div class="chrz-mobile">
    <div class="chrz-carousel" id="chrz-carousel" aria-label="Case studies carousel">
      {allCards.map((card) => <ChrzCard card={card} />)}
    </div>
    <div class="chrz-carousel__nav">
      <button type="button" class="chrz-carousel__btn" data-chrz-dir="-1" aria-label="Previous case study">←</button>
      <span class="chrz-carousel__count">
        <b id="chrz-carousel-current">1</b>
        <span aria-hidden="true">/</span>
        {allCards.length}
      </span>
      <button type="button" class="chrz-carousel__btn" data-chrz-dir="1" aria-label="Next case study">→</button>
    </div>
  </div>
</section>

<style>
  .chrz-exp {
    position: relative;
    width: 100%;
    margin: 0;
    overflow: hidden;
    padding: 88px 0 96px;
    /* Fades white → soft warm tint → white so it blends into the
       sections above and below instead of sitting in a hard box */
    background: linear-gradient(180deg, #ffffff 0%, #fbf5ea 18%, #faf3e6 50%, #fbf5ea 82%, #ffffff 100%);
  }

  /* Hairline glows at the seams for a soft hand-off between sections */
  .chrz-exp::before,
  .chrz-exp::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: min(720px, 80%);
    height: 1px;
    background: linear-gradient(90deg, transparent, #ebddbe, transparent);
  }

  .chrz-exp::before {
    top: 0;
  }

  .chrz-exp::after {
    bottom: 0;
  }

  .chrz-exp__head {
    text-align: center;
    padding: 0 24px;
    margin-bottom: 40px;
  }

  .chrz-exp__pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid #cdc4f5;
    color: #6d5bd0;
    background: #ffffff;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 18px;
  }

  .chrz-exp__pill::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6d5bd0;
  }

  .chrz-exp__title {
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #17151f;
    margin: 0 0 10px;
  }

  .chrz-exp__title em {
    font-style: normal;
    color: #6d5bd0;
  }

  .chrz-exp__sub {
    font-size: 13px;
    color: #8a8494;
    margin: 0;
    font-weight: 500;
  }

  /* ---------- Marquee rows (desktop / tablet) ---------- */

  .chrz-marquee {
    position: relative;
    display: flex;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }

  .chrz-marquee + .chrz-marquee {
    margin-top: 20px;
  }

  .chrz-track {
    display: flex;
    gap: 20px;
    padding: 4px 10px;
    flex-shrink: 0;
    min-width: 100%;
    animation: chrz-scroll-left 55s linear infinite;
  }

  .chrz-marquee--reverse .chrz-track {
    animation-name: chrz-scroll-right;
  }

  .chrz-marquee:hover .chrz-track {
    animation-play-state: paused;
  }

  @keyframes chrz-scroll-left {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-100% - 20px));
    }
  }

  @keyframes chrz-scroll-right {
    from {
      transform: translateX(calc(-100% - 20px));
    }

    to {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chrz-track {
      animation: none;
    }

    .chrz-marquee {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  /* ---------- Mobile carousel ---------- */

  .chrz-mobile {
    display: none;
  }

  .chrz-carousel {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 4px 24px 12px;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .chrz-carousel::-webkit-scrollbar {
    display: none;
  }

  .chrz-carousel :global(.chrz-card) {
    width: min(340px, calc(100vw - 72px));
    scroll-snap-align: center;
  }

  .chrz-carousel__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 16px;
  }

  .chrz-carousel__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid #e4d3ae;
    background: #ffffff;
    color: #6d5bd0;
    font-size: 17px;
    font-weight: 700;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .chrz-carousel__btn:active {
    background: #f6f4fe;
    border-color: #cdc4f5;
  }

  .chrz-carousel__count {
    display: flex;
    align-items: baseline;
    gap: 5px;
    font-size: 13px;
    font-weight: 600;
    color: #8a8494;
    min-width: 52px;
    justify-content: center;
  }

  .chrz-carousel__count b {
    color: #17151f;
    font-weight: 800;
  }

  @media (max-width: 767px) {
    .chrz-marquee {
      display: none;
    }

    .chrz-mobile {
      display: block;
    }

    .chrz-exp {
      padding: 64px 0 72px;
    }
  }
</style>

<script>
  const carousel = document.getElementById('chrz-carousel');
  const current = document.getElementById('chrz-carousel-current');
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-chrz-dir]');

  if (carousel && current) {
    const step = () => {
      const card = carousel.querySelector<HTMLElement>('.chrz-card');
      return card ? card.offsetWidth + 14 : carousel.clientWidth;
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        carousel.scrollBy({ left: Number(button.dataset.chrzDir) * step(), behavior: 'smooth' });
        window.posthog?.capture('case_study_carousel_navigated', {
          direction: Number(button.dataset.chrzDir) > 0 ? 'next' : 'previous',
        });
      });
    });

    let ticking = false;
    carousel.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const index = Math.round(carousel.scrollLeft / step()) + 1;
          const total = carousel.querySelectorAll('.chrz-card').length;
          current.textContent = String(Math.min(Math.max(index, 1), total));
          ticking = false;
        });
      },
      { passive: true }
    );
  }
</script>
