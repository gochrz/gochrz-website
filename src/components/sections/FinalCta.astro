---
import { Icon } from 'astro-icon/components';

const calendlyUrl = 'https://calendly.com/ben-chrzanowski/chrz-intro-call';

const pillars = [
  { icon: 'lucide:users', className: 'p1', label: 'Audience' },
  { icon: 'lucide:radio', className: 'p2', label: 'Signal' },
  { icon: 'lucide:trending-up', className: 'p3', label: 'Growth' },
];
---

<section id="book" class="cta-section relative overflow-hidden">
  <span class="cta-blob cta-blob--1" aria-hidden="true"></span>
  <span class="cta-blob cta-blob--2" aria-hidden="true"></span>
  <span class="cta-blob cta-blob--3" aria-hidden="true"></span>

  <div class="section-shell relative text-center">
    <div class="mx-auto max-w-3xl">
      <div class="reveal cta-pillars" aria-hidden="true">
        {
          pillars.map((pillar, index) => (
            <>
              <span class={`cta-pillar ${pillar.className}`} title={pillar.label}>
                <Icon name={pillar.icon} class="h-[23px] w-[23px]" />
              </span>
              {index < 2 && <span class={`cta-link ${index === 1 ? 'cta-link--late' : ''}`} />}
            </>
          ))
        }
      </div>

      <h2 class="reveal cta-heading">
        Ready to build your<br />
        <span class="grad">growth system?</span>
      </h2>
      <p class="reveal cta-sub">Book a call and we'll map the three pillars to your business.</p>

      <a href={calendlyUrl} target="_blank" rel="noopener" class="reveal cta-btn group" id="final-cta-book-call">
        <span class="shine" aria-hidden="true"></span>
        <Icon name="lucide:calendar" class="h-[17px] w-[17px]" aria-hidden="true" />
        Book a Systems Call
        <span class="arrow" aria-hidden="true">→</span>
      </a>

      <div class="reveal cta-note">
        <Icon name="lucide:check" class="h-3.5 w-3.5 flex-none text-[#10b981]" aria-hidden="true" />
        Free 30-minute strategy session · No pitch, just the map
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: #f6f7fd;
    padding: 100px 0 120px;
  }

  .cta-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.5;
    pointer-events: none;
    animation: cta-drift 14s ease-in-out infinite alternate;
  }

  .cta-blob--1 {
    width: 420px;
    height: 420px;
    background: #dde1ff;
    top: -140px;
    left: -100px;
  }

  .cta-blob--2 {
    width: 380px;
    height: 380px;
    background: #e7dbff;
    bottom: -160px;
    right: -80px;
    animation-delay: -7s;
  }

  .cta-blob--3 {
    width: 260px;
    height: 260px;
    background: #d3f5e8;
    bottom: -60px;
    left: 32%;
    animation-delay: -3.5s;
  }

  @keyframes cta-drift {
    from {
      transform: translate(0, 0) scale(1);
    }

    to {
      transform: translate(36px, -28px) scale(1.08);
    }
  }

  .cta-pillars {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 38px;
  }

  @keyframes cta-bob {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-7px);
    }
  }

  .cta-pillar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    color: white;
    box-shadow: 0 10px 24px -8px var(--glow);
    animation: cta-bob 3.4s ease-in-out infinite;
  }

  .cta-pillar.p1 {
    background: linear-gradient(140deg, #5b54f0, #4f46e5);
    --glow: rgba(79, 70, 229, 0.55);
  }

  .cta-pillar.p2 {
    background: linear-gradient(140deg, #9b6df7, #8b5cf6);
    --glow: rgba(139, 92, 246, 0.55);
    animation-delay: 0.45s;
  }

  .cta-pillar.p3 {
    background: linear-gradient(140deg, #1cc98f, #10b981);
    --glow: rgba(16, 185, 129, 0.55);
    animation-delay: 0.9s;
  }

  .cta-link {
    position: relative;
    width: 56px;
    height: 2px;
    overflow: hidden;
    background: var(--color-line);
  }

  @keyframes cta-flow {
    to {
      left: 100%;
    }
  }

  .cta-link::after {
    content: '';
    position: absolute;
    top: 0;
    left: -40%;
    height: 100%;
    width: 40%;
    background: linear-gradient(90deg, transparent, #8b5cf6, transparent);
    animation: cta-flow 1.8s linear infinite;
  }

  .cta-link--late::after {
    animation-delay: 0.9s;
  }

  .cta-heading {
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.06;
    color: var(--color-ink);
  }

  .cta-heading .grad {
    background: linear-gradient(92deg, #4f46e5, #8b5cf6 55%, #10b981);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .cta-sub {
    margin: 18px auto 40px;
    max-width: 440px;
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-body);
  }

  .cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    overflow: hidden;
    border-radius: 14px;
    background: linear-gradient(92deg, #4f46e5, #8b5cf6);
    padding: 17px 32px;
    font-size: 15.5px;
    font-weight: 600;
    color: white;
    box-shadow: 0 14px 30px -10px rgba(79, 70, 229, 0.5);
    transition:
      transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.35s ease;
  }

  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -12px rgba(79, 70, 229, 0.6);
  }

  .cta-btn:active {
    transform: translateY(-1px);
  }

  .cta-btn:focus-visible {
    outline: 3px solid #4f46e5;
    outline-offset: 3px;
  }

  @keyframes cta-shine {
    0%,
    55% {
      left: -80%;
    }

    75%,
    100% {
      left: 130%;
    }
  }

  .cta-btn .shine {
    position: absolute;
    top: 0;
    left: -80%;
    height: 100%;
    width: 50%;
    background: linear-gradient(105deg, transparent, rgba(255, 255, 255, 0.35), transparent);
    transform: skewX(-20deg);
    animation: cta-shine 3.4s ease-in-out infinite;
  }

  .cta-btn .arrow {
    transition: transform 0.3s ease;
  }

  .cta-btn:hover .arrow {
    transform: translateX(4px);
  }

  .cta-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    margin-top: 18px;
    font-size: 13px;
    color: var(--color-body);
  }
</style>

<script is:inline>
  document.getElementById('final-cta-book-call')?.addEventListener('click', function () {
    window.posthog?.capture('book_call_clicked', { location: 'final_cta' });
  });
</script>
