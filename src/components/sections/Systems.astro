---
const systems = [
  {
    code: 'OUT/01',
    name: 'Outbound Systems',
    specs: [
      { label: 'Function', value: "Works when it's engineered, not improvised." },
      { label: 'Method', value: 'Target a defined ICP. Run without manual effort. Improve based on data.' },
      { label: 'Outcome', value: 'A controllable source of pipeline.' },
    ],
  },
  {
    code: 'PAID/02',
    name: 'Paid Acquisition Systems',
    specs: [
      { label: 'Function', value: "Paid works when it's connected to revenue." },
      { label: 'Method', value: 'Match offer economics. Route demand into qualification. Scale without breaking CAC.' },
      { label: 'Outcome', value: 'Pipeline you can increase on demand.' },
    ],
  },
  {
    code: 'ORG/03',
    name: 'Organic Distribution Systems',
    specs: [
      { label: 'Function', value: "Organic works when it's repeatable." },
      { label: 'Method', value: 'LinkedIn distribution. Email capture. Content repurposing.' },
      { label: 'Outcome', value: 'Compounding inbound demand.' },
    ],
  },
];
---

<section id="systems" class="border-t border-line py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 flex items-center justify-between gap-4">
      <span class="mono-label">SYS/03 — Installed systems</span>
    </div>

    <div class="reveal max-w-3xl">
      <h2 class="display-sub text-[clamp(1.8rem,4.5vw,3.2rem)]">
        Scalable channels we build.
      </h2>
    </div>

    <div class="mt-12 space-y-4">
      {
        systems.map((system, index) => (
          <article class="panel-raised bracket reveal grid gap-8 p-6 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.4fr)] md:p-8" data-reveal-delay={String(index * 0.1)}>
            <div>
              <span class="mono-label">{system.code}</span>
              <h3 class="display-sub mt-4 text-2xl">{system.name}</h3>
            </div>
            <div>
              {system.specs.map((spec) => (
                <div class="grid gap-3 border-t border-line py-4 md:grid-cols-[9rem_1fr]">
                  <span class="mono-label">{spec.label}</span>
                  <p class="leading-relaxed text-text">{spec.value}</p>
                </div>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
