---
const calendlyUrl = 'https://calendly.com/ben-chrzanowski/chrz-intro-call';
---

<section id="top" class="relative overflow-hidden pt-16">
  <div class="mesh-bg" aria-hidden="true">
    <span class="mesh-blob left-[-8rem] top-10 bg-blue"></span>
    <span class="mesh-blob right-[-7rem] top-20 bg-violet"></span>
    <span class="mesh-blob bottom-4 left-1/3 bg-cyan"></span>
    <span class="mesh-blob right-1/4 top-44 bg-amber opacity-[0.1]"></span>
  </div>

  <div class="section-shell relative grid min-h-[calc(100vh-4rem)] items-center gap-12 py-20 lg:grid-cols-[1.04fr_0.96fr]">
    <div class="reveal max-w-3xl">
      <h1 class="mt-6 text-5xl font-extrabold leading-[1.02] text-ink sm:text-6xl lg:text-7xl">
        B2B Marketing Designed for the <span class="gradient-text">New World</span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-body sm:text-xl">
        We help B2B SaaS companies, service businesses, and creator businesses generate revenue through live events, industry personalities, and social content.
      </p>
      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a href={calendlyUrl} target="_blank" rel="noopener" class="primary-button group">
          Book a Systems Call
          <span aria-hidden="true" class="button-arrow">→</span>
        </a>
        <a href="#pillars" class="ghost-button">
          See the three pillars ↓
        </a>
      </div>
    </div>

    <div class="reveal relative mx-auto w-full max-w-md lg:max-w-none" data-reveal-delay="0.12">
      <div class="absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-blue/10 via-violet/10 to-cyan/10 blur-2xl" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-2xl border border-line bg-white p-6 shadow-2xl shadow-blue/10 sm:p-7">
        <h2 class="sr-only">Animated hero graphic showing a live webinar with attendees joining in real time, alongside network stats</h2>

        <div class="flex items-center gap-2">
          <span class="hero-livedot inline-block h-2 w-2 rounded-full bg-[#e24b4a]" aria-hidden="true"></span>
          <span class="text-sm font-bold text-ink">Live now</span>
        </div>

        <div class="mt-4 overflow-hidden rounded-2xl border border-line bg-surface p-5">
          <div class="flex items-baseline gap-2">
            <span id="hero-counter" class="font-display text-3xl font-extrabold text-ink">842</span>
            <span class="text-sm font-semibold text-body">attendees</span>
          </div>
          <div id="hero-avatar-row" class="mt-4 flex gap-1.5" aria-hidden="true"></div>
        </div>

        <p id="hero-ticker" class="mt-3 h-5 text-sm text-body" aria-hidden="true"></p>

        <div class="mt-4 grid grid-cols-2 gap-4">
          <div class="rounded-2xl border border-line bg-surface p-5">
            <p class="gradient-text font-display text-3xl font-extrabold sm:text-4xl">1,000+</p>
            <p class="mt-2 text-sm font-bold text-body">B2B creators in network</p>
          </div>
          <div class="rounded-2xl border border-line bg-surface p-5">
            <p class="gradient-text font-display text-3xl font-extrabold sm:text-4xl">1,000+</p>
            <p class="mt-2 text-sm font-bold text-body">Live hours</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @keyframes hero-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  @keyframes hero-popin {
    from {
      transform: scale(0);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .hero-livedot {
    animation: hero-pulse 1.4s ease-in-out infinite;
  }

  .hero-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-size: 11px;
    font-weight: 600;
    animation: hero-popin 0.35s ease-out backwards;
  }
</style>

<script>
  const ramps = [
    { bg: '#cecbf6', fg: '#26215c' },
    { bg: '#9fe1cb', fg: '#04342c' },
    { bg: '#f5c4b3', fg: '#4a1b0c' },
    { bg: '#f4c0d1', fg: '#4b1528' },
    { bg: '#b5d4f4', fg: '#042c53' },
    { bg: '#c0dd97', fg: '#173404' },
  ];
  const names = ['Maya R.', 'Jordan K.', 'Priya S.', 'Alex T.', 'Sam O.', 'Nina F.', 'Ravi P.', 'Ella W.'];

  const counter = document.getElementById('hero-counter');
  const row = document.getElementById('hero-avatar-row');
  const ticker = document.getElementById('hero-ticker');
  let count = 842;
  let i = 0;

  function addAvatar() {
    if (!counter || !row || !ticker) return;
    const ramp = ramps[i % ramps.length];
    const name = names[i % names.length];
    const initials = name
      .split(' ')
      .map((part) => part[0])
      .join('');

    const el = document.createElement('div');
    el.className = 'hero-avatar';
    el.style.background = ramp.bg;
    el.style.color = ramp.fg;
    el.textContent = initials;
    row.appendChild(el);
    if (row.children.length > 8) row.removeChild(row.firstChild as Node);

    ticker.textContent = `${name} just joined`;
    count += Math.floor(Math.random() * 3) + 1;
    counter.textContent = count.toLocaleString();
    i++;
  }

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reducedMotion) {
    for (let seed = 0; seed < 5; seed++) addAvatar();
  } else {
    addAvatar();
    setInterval(addAvatar, 1400);
  }
</script>
