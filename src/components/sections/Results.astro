---
const cases = [
  {
    industry: 'Creator education',
    metric: '$10k → $100k+ /mo',
    system: 'Webinar revenue system',
    funnel: 'free community → webinar → offer',
    channel: 'organic + community',
  },
  {
    industry: 'B2B AI SaaS',
    metric: '$100k+ /mo',
    system: 'Paid webinar growth system',
    funnel: 'paid traffic → webinar → subscription',
    channel: 'paid',
  },
  {
    industry: 'Edtech platform',
    metric: '1 → 1,000+ users',
    system: 'Organic distribution system',
    funnel: 'content → email capture → activation',
    channel: 'organic + email',
  },
  {
    industry: 'Martech SaaS',
    metric: '$5k → $20k /mo',
    system: 'Paid-to-VSL system',
    funnel: 'paid → VSL → trial',
    channel: 'paid',
  },
  {
    industry: 'B2B services',
    metric: '20 contracts closed',
    system: 'LinkedIn outbound system',
    funnel: 'outbound → qualification → call',
    channel: 'outbound',
  },
  {
    industry: 'Founder-led B2B',
    metric: 'Multi-6 figures',
    system: 'Service-to-software system',
    funnel: 'outbound + referrals → offer',
    channel: 'outbound + email',
  },
];
---

<section id="results" class="border-t border-line py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 flex items-center justify-between gap-4">
      <span class="mono-label">SYS/07 — Field data</span>
      <span class="mono-label hidden max-w-xs text-right md:block">
        Revenue systems we've installed for B2B companies
      </span>
    </div>

    <div class="reveal max-w-3xl">
      <h2 class="display-sub text-[clamp(1.8rem,4.5vw,3.2rem)]">
        Real systems. Real results.
      </h2>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        cases.map((item, index) => (
          <article class="panel bracket reveal p-6" data-reveal-delay={String((index % 3) * 0.1)}>
            <span class="mono-label">{item.industry}</span>
            <h3 class="display-sub mt-5 text-2xl">{item.metric}</h3>
            <p class="mt-3 text-muted">{item.system}</p>
            <div class="mt-6">
              <div class="grid gap-2 border-t border-line py-4">
                <span class="mono-label">Funnel</span>
                <span class="mono-data text-sm text-text">{item.funnel}</span>
              </div>
              <div class="grid gap-2 border-t border-line py-4">
                <span class="mono-label">Channel</span>
                <span class="mono-data text-sm text-text">{item.channel}</span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
