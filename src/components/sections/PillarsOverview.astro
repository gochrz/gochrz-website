---
import { Icon } from 'astro-icon/components';

const pillars = [
  {
    number: '01',
    icon: 'lucide:users',
    title: 'B2B Influencer Marketing',
    tagline: 'Trust is transferred.',
    href: '#influencer',
    hoverClass: 'hover:border-blue hover:shadow-blue/15',
    textClass: 'text-blue',
    chipClass: 'bg-[#eff6ff] text-blue',
    tint: '#eff6ff',
  },
  {
    number: '02',
    icon: 'lucide:radio',
    title: 'Digital Live Events',
    tagline: 'Trust is built live.',
    href: '#events',
    hoverClass: 'hover:border-violet hover:shadow-violet/15',
    textClass: 'text-violet',
    chipClass: 'bg-[#f5f3ff] text-violet',
    tint: '#f5f3ff',
  },
  {
    number: '03',
    icon: 'lucide:trending-up',
    title: 'Revenue Expansion',
    tagline: 'Take the trust you have and scale it.',
    href: '#revenue',
    hoverClass: 'hover:border-emerald hover:shadow-emerald/15',
    textClass: 'text-emerald',
    chipClass: 'bg-[#ecfdf5] text-emerald',
    tint: '#ecfdf5',
  },
];
---

<section id="pillars" class="bg-white py-20 md:py-28">
  <div class="section-shell">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        Our business is built around three pillars that work together.
      </h2>
    </div>

    <div class="relative mt-14 grid gap-10 md:grid-cols-3 md:gap-6">
      <div
        class="absolute left-[16.66%] right-[16.66%] top-16 hidden border-t-2 border-dashed border-line md:block"
        aria-hidden="true"
      ></div>
      {
        pillars.map((pillar, index) => (
          <a
            href={pillar.href}
            class={`lift-card reveal group relative flex flex-col p-8 hover:shadow-xl ${pillar.hoverClass}`}
            style={`background: linear-gradient(180deg, ${pillar.tint}, #ffffff 55%)`}
            data-reveal-delay={index * 0.08}
          >
            <div class="flex items-start justify-between gap-4">
              <span class={`flex h-16 w-16 items-center justify-center rounded-2xl ${pillar.chipClass}`}>
                <Icon name={pillar.icon} class="h-8 w-8" aria-hidden="true" />
              </span>
              <span class={`font-display text-xl font-extrabold tracking-tight ${pillar.textClass}`}>{pillar.number}</span>
            </div>
            <h3 class="mt-8 text-2xl font-extrabold leading-tight text-ink">{pillar.title}</h3>
            <p class="mt-3 text-lg font-semibold leading-7 text-body">{pillar.tagline}</p>
            <span class={`mt-auto inline-flex items-center gap-2 pt-8 text-sm font-extrabold ${pillar.textClass}`}>
              Explore
              <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" aria-hidden="true" />
            </span>
            {index < 2 && (
              <span
                class="absolute -bottom-8 left-1/2 -translate-x-1/2 rotate-90 text-body md:-right-[1.4rem] md:bottom-auto md:left-auto md:top-14 md:translate-x-0 md:rotate-0"
                aria-hidden="true"
              >
                <Icon name="lucide:chevrons-right" class="h-6 w-6" />
              </span>
            )}
          </a>
        ))
      }
    </div>

    <p class="reveal mx-auto mt-14 max-w-3xl text-center text-xl font-semibold leading-8 text-ink">
      Each can be used independently, but they're most powerful when combined into a single growth system.
    </p>
  </div>
</section>
